# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Signs session cookies when using Supabase (min 32 chars)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Optional: Web Push (npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Optional: replace with your IARC ID from https://portal.globalratings.com/ (see docs/PWA.md)
# Manifest iarc_rating_id is set in public/manifest.json
