# Neon Postgres (server only — never expose DATABASE_URL to the browser)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Required for staff login sessions (min 16 characters)
SESSION_SECRET=change-me-to-a-long-random-string

# Client: use /api/* routes instead of localStorage
NEXT_PUBLIC_USE_SERVER_DB=true

# Fixed workspace for this deployment (must match tenants.slug in Neon)
NEXT_PUBLIC_WORKSPACE_ID=happus

# Web Push (optional) — run: npx web-push generate-vapid-keys
# Put keys in .env.local (never commit). Restart `npm run dev` after adding.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
