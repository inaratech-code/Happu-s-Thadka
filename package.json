{
  "name": "happus-tadka",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next node_modules/.cache .next-dev.lock",
    "dev:stop": "node scripts/kill-dev-servers.mjs",
    "predev": "node scripts/ensure-next-cache.mjs",
    "dev": "node scripts/dev-with-lock.mjs",
    "dev:clean": "node scripts/kill-dev-servers.mjs && npm run clean && node scripts/dev-with-lock.mjs",
    "prebuild": "node scripts/ensure-next-cache.mjs --prebuild",
    "build": "next build",
    "rebuild": "npm run clean && npm run build",
    "prestart": "node scripts/ensure-next-cache.mjs --production",
    "start": "next start -H 127.0.0.1",
    "lint": "next lint",
    "db:migrate": "node scripts/run-migrations.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.4.7",
    "jose": "^6.2.3",
    "lucide-react": "^0.475.0",
    "nepali-date-converter": "^3.4.0",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.9",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.20.1",
    "eslint-config-next": "^15.2.0",
    "tailwindcss": "^4.0.9",
    "typescript": "^5.7.3"
  }
}
