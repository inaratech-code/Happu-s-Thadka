{
  "id": "/",
  "name": "Happus Tadka — Restaurant POS & ERP",
  "short_name": "Happus Tadka",
  "description": "Offline-first restaurant POS and ERP for Happus Tadka, Mahendinagar",
  "categories": ["business", "food", "productivity"],
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "tabbed",
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "iarc_rating_id": "37bf1ef0-98b4-4cef-a6e7-0e7d3a1e6c6d",
  "orientation": "any",
  "lang": "en",
  "dir": "ltr",
  "background_color": "#0a0a0b",
  "theme_color": "#0a0a0b",
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "webapp",
      "url": "/",
      "id": "happus-tadka"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "edge_side_panel": {
    "preferred_width": 480
  },
  "scope_extensions": [
    {
      "type": "origin",
      "origin": "https://happus-tadka.vercel.app"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+happustadka",
      "url": "/?launch=%s"
    }
  ],
  "share_target": {
    "action": "/",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "application/json": [".json"]
      },
      "icons": [
        {
          "src": "/icons/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "note_taking": {
    "new_note_url": "/transactions/sales"
  },
  "widgets": [
    {
      "name": "Today's Sales",
      "short_name": "Sales",
      "description": "Today's revenue at a glance",
      "tag": "today-sales",
      "template": "template",
      "data": "/api/widget/today-sales",
      "type": "application/json",
      "auth": true,
      "update": 3600,
      "icons": [
        {
          "src": "/icons/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "screenshots": []
    }
  ],
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/mobile-390x844.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Happus Tadka POS"
    },
    {
      "src": "/screenshots/desktop-1280x720.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Restaurant management dashboard"
    }
  ],
  "shortcuts": [
    {
      "name": "Point of Sale",
      "short_name": "POS",
      "description": "Open cashier",
      "url": "/pos",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Kitchen Display",
      "short_name": "Kitchen",
      "description": "Kitchen orders",
      "url": "/kitchen",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Inventory",
      "short_name": "Stock",
      "description": "Manage inventory",
      "url": "/inventory",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Record Sale",
      "short_name": "Sale",
      "description": "Record a new sale",
      "url": "/transactions/sales",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ]
}
